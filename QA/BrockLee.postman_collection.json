        {
          "name": "Parse — Large Input (Performance)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Generate 1000 expenses dynamically",
                  "const expenses = [];",
                  "const baseDate = new Date('2023-01-01T00:00:00');",
                  "for (let i = 0; i < 1000; i++) {",
                  "  const d = new Date(baseDate.getTime() + i * 60000);",
                  "  expenses.push({",
                  "    date: d.toISOString().replace('Z',''),",
                  "    amount: Math.floor(Math.random() * 49900) + 100",
                  "  });",
                  "}",
                  "pm.collectionVariables.set('largeExpenses', JSON.stringify(expenses));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Returns 1000 transactions', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.transactions).to.have.lengthOf(1000);",
                  "});",
                  "",
                  "pm.test('Response time < 2000ms for 1000 expenses', () => {",
                  "  pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{apiBase}}/transactions:parse",
            "body": {
              "mode": "raw",
              "raw": "{\"expenses\": {{largeExpenses}}}"
            }
          }
        }
      ]
