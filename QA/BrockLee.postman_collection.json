{
  "info": {
    "name": "BrockLee — Auto-Savings API",
    "description": "Complete test suite for BrockLee Auto-Savings Retirement API.\n\nBase URL: http://localhost:5477\n\nTest Order:\n1. Health Check\n2. Transactions: Parse\n3. Transactions: Validator\n4. Transactions: Filter\n5. Returns: NPS\n6. Returns: Index\n7. Returns: Compute (used by Angular UI)\n8. Logs\n9. Performance\n\nRun via:\n  Collection Runner (in order)\n  OR: newman run BrockLee.postman_collection.json",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5477",
      "type": "string"
    },
    {
      "key": "apiBase",
      "value": "{{baseUrl}}/blackrock/challenge/v1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🟢 Health",
      "item": [
        {
          "name": "Health Check",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has status field', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('status');",
                  "  pm.expect(body.status).to.eql('healthy');",
                  "});",
                  "",
                  "pm.test('Response has timestamp', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('timestamp');",
                  "});",
                  "",
                  "pm.test('Response has mode field', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('mode');",
                  "  pm.expect(['full-stack', 'api-only']).to.include(body.mode);",
                  "});",
                  "",
                  "pm.test('Response time < 500ms', () => {",
                  "  pm.expect(pm.response.responseTime).to.be.below(500);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "📋 Transactions: Parse",
      "item": [
        {
          "name": "Parse — Challenge Example (Happy Path)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Returns 4 transactions', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.transactions).to.have.lengthOf(4);",
                  "});",
                  "",
                  "pm.test('Total remanent = 175 (challenge spec)', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.totalRemanent).to.eql(175);",
                  "});",
                  "",
                  "pm.test('Total ceiling = 2000', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.totalCeiling).to.eql(2000);",
                  "});",
                  "",
                  "pm.test('Total expense = 1725', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.totalExpense).to.eql(1725);",
                  "});",
                  "",
                  "pm.test('Expense 250 → ceiling 300, remanent 50', () => {",
                  "  const body = pm.response.json();",
                  "  const tx = body.transactions.find(t => t.amount === 250);",
                  "  pm.expect(tx).to.not.be.undefined;",
                  "  pm.expect(tx.ceiling).to.eql(300);",
                  "  pm.expect(tx.remanent).to.eql(50);",
                  "});",
                  "",
                  "pm.test('Expense 375 → ceiling 400, remanent 25', () => {",
                  "  const body = pm.response.json();",
                  "  const tx = body.transactions.find(t => t.amount === 375);",
                  "  pm.expect(tx.ceiling).to.eql(400);",
                  "  pm.expect(tx.remanent).to.eql(25);",
                  "});",
                  "",
                  "pm.test('Expense 620 → ceiling 700, remanent 80', () => {",
                  "  const body = pm.response.json();",
                  "  const tx = body.transactions.find(t => t.amount === 620);",
                  "  pm.expect(tx.ceiling).to.eql(700);",
                  "  pm.expect(tx.remanent).to.eql(80);",
                  "});",
                  "",
                  "pm.test('Expense 480 → ceiling 500, remanent 20', () => {",
                  "  const body = pm.response.json();",
                  "  const tx = body.transactions.find(t => t.amount === 480);",
                  "  pm.expect(tx.ceiling).to.eql(500);",
                  "  pm.expect(tx.remanent).to.eql(20);",
                  "});",
                  "",
                  "// Store parsed transactions for downstream tests",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('parsedTransactions', JSON.stringify(body.transactions));"
                ]
              }
            }
