    {
      "name": "🔀 Transactions: Filter",
      "item": [
        {
          "name": "Filter — Challenge Example (Q + P + K)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Returns valid transactions', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.valid).to.have.lengthOf(4);",
                  "});",
                  "",
                  "pm.test('July transaction remanent = 0 (Q period applied)', () => {",
                  "  const body = pm.response.json();",
                  "  const julyTx = body.valid.find(t => t.date.startsWith('2023-07'));",
                  "  pm.expect(julyTx).to.not.be.undefined;",
                  "  pm.expect(julyTx.remanent).to.eql(0);",
                  "});",
                  "",
                  "pm.test('Oct transaction remanent = 75 (P period adds 25)', () => {",
                  "  const body = pm.response.json();",
                  "  const octTx = body.valid.find(t => t.date.startsWith('2023-10'));",
                  "  pm.expect(octTx.remanent).to.eql(75);",
                  "});",
                  "",
                  "pm.test('Dec transaction remanent = 45 (P period adds 25)', () => {",
                  "  const body = pm.response.json();",
                  "  const decTx = body.valid.find(t => t.date.startsWith('2023-12'));",
                  "  pm.expect(decTx.remanent).to.eql(45);",
                  "});",
                  "",
                  "pm.test('Feb transaction remanent = 25 (no Q or P applied)', () => {",
                  "  const body = pm.response.json();",
                  "  const febTx = body.valid.find(t => t.date.startsWith('2023-02'));",
                  "  pm.expect(febTx.remanent).to.eql(25);",
                  "});",
                  "",
                  "pm.test('K group Mar-Nov sum = 75', () => {",
                  "  const body = pm.response.json();",
                  "  const marNov = body.kGroups.find(g =>",
                  "    g.start.startsWith('2023-03') && g.end.startsWith('2023-11'));",
                  "  pm.expect(marNov).to.not.be.undefined;",
                  "  pm.expect(marNov.amount).to.eql(75);",
                  "});",
                  "",
                  "pm.test('K group full year sum = 145', () => {",
                  "  const body = pm.response.json();",
                  "  const fullYear = body.kGroups.find(g =>",
                  "    g.start.startsWith('2023-01') && g.end.startsWith('2023-12'));",
                  "  pm.expect(fullYear).to.not.be.undefined;",
                  "  pm.expect(fullYear.amount).to.eql(145);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{apiBase}}/transactions:filter",
