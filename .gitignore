# ── Environment files ─────────────────────────────────────────
.env.production
.env.development
.env.local
.env

# Safe to commit:
# .env.example  ← template with no real values

# ── .NET ─────────────────────────────────────────────────────
**/bin/
**/obj/
*.user
*.db
*.db-shm
*.db-wal

# ── Angular ───────────────────────────────────────────────────
brockui/node_modules/
brockui/dist/

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.pyc
PythonScripts/__pycache__/

# ── Docker ───────────────────────────────────────────────────
.dockerignore

# Kaggle datasets — may contain PII, never commit
PythonScripts/data/*.csv
PythonScripts/data/*.xlsx
PythonScripts/data/*.json
PythonScripts/
PythonScripts/.venv/*


# See https://docs.github.com/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

